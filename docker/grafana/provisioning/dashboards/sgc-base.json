{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "SGC Angola — Base",
  "uid": "sgc-base",
  "tags": ["sgc", "m1"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Taxa de pedidos HTTP (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(sgc_http_pedidos_total[1m])) by (rota, codigo)",
          "legendFormat": "{{rota}} ({{codigo}})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Latência P95 por rota (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(sgc_http_duracao_segundos_bucket[5m])) by (le, rota))",
          "legendFormat": "{{rota}}",
          "refId": "A"
        }
      ]
    }
  ]
}
