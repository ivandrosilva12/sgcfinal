# Configuração de exemplo (dev). Copiar para .env e ajustar.
# NUNCA versionar o .env real. Em produção os segredos vêm de Vault/Sealed
# Secrets, não de ficheiro .env (ver adrs/ADR-020-fundacao-m1.md).

# Ambiente: dev | staging | prod
APP_ENV=dev

# Servidor HTTP
HTTP_PORT=8080
LOG_LEVEL=info

# PostgreSQL (pgx). No compose, host = "postgres".
#
# DUAS credenciais, desde a ADR-043 (R7):
#   DATABASE_URL           — runtime (sgc_app). Sem DDL, não é dono de nada. É a
#                            única que o processo servidor precisa de ter.
#   DATABASE_MIGRATION_URL — migrador (sgc). Só para `make migrate` e testes de
#                            integração. NÃO a coloque no ambiente do servidor.
DATABASE_URL=postgres://sgc_app:sgc_app@localhost:5432/sgc?sslmode=disable
DATABASE_MIGRATION_URL=postgres://sgc:sgc@localhost:5432/sgc?sslmode=disable

# Redis. No compose, host = "redis".
REDIS_URL=redis://localhost:6379/0

# Keycloak (OIDC) — obrigatório desde M1/Sprint 2. Em Docker: host = "keycloak"
# e porta 8080 (o issuer do token tem de coincidir com o que a API valida).
KEYCLOAK_ISSUER=http://localhost:8081/realms/sgc
KEYCLOAK_AUDIENCE=sgc-api

# Client confidencial para a Admin REST API do Keycloak (gestão de utilizadores/
# papéis). Service account com roles realm-management (view-users, query-users, manage-users, view-realm).
KEYCLOAK_ADMIN_CLIENT_ID=sgc-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=segredo-admin

# Valores do claim "acr" considerados autenticação forte (MFA), separados por
# vírgulas. Por omissão: mfa,gold,2.
# Estes valores TÊM de coincidir com o "acr" (ou "amr") que o realm Keycloak
# realmente emite para logins com segundo factor (OTP); caso contrário, os
# papéis sensíveis (Director/Admin/DPO/Auditor) ficam sem acesso — a
# imposição de MFA é fail-closed. Ver adrs/ADR-022-mfa-gestao-admin.md.
KEYCLOAK_ACR_FORTE=mfa,gold,2

# Nota: o realm mapeia OTP → acr (acr.loa.map) para o MFA positivo — ver ADR-023.

# --- SMTP (notificações por email) ---
# SMTP_HOST vazio → notificações desactivadas (fallback no-op). Em dev, MailHog.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=nao-responder@sgc.ao

# CORS: lista de origens separada por vírgulas. Vazio em dev = todas ("*");
# em staging/prod tem de ser definido explicitamente.
CORS_ORIGINS=

# Rate limiting por IP (pedidos por minuto). Por omissão: 100.
RATE_LIMIT_IP=100

# MinIO (documentos) — usado em marco futuro.
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=sgc
MINIO_SECRET_KEY=sgc-secreto
MINIO_BUCKET=documentos
