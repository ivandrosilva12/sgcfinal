# Configuração de exemplo (dev). Copiar para .env e ajustar.
# NUNCA versionar o .env real. Em produção os segredos vêm de Vault/Sealed
# Secrets, não de ficheiro .env (ver adrs/ADR-020-fundacao-m1.md).

# Ambiente: dev | staging | prod
APP_ENV=dev

# Servidor HTTP
HTTP_PORT=8080
LOG_LEVEL=info

# PostgreSQL (pgx). No compose, host = "postgres".
DATABASE_URL=postgres://sgc:sgc@localhost:5432/sgc?sslmode=disable

# Redis. No compose, host = "redis".
REDIS_URL=redis://localhost:6379/0

# Keycloak (OIDC) — usado a partir de M1/Sprint 2.
KEYCLOAK_ISSUER=http://localhost:8081/realms/sgc
KEYCLOAK_AUDIENCE=sgc-api

# MinIO (documentos) — usado em marco futuro.
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=sgc
MINIO_SECRET_KEY=sgc-secreto
MINIO_BUCKET=documentos
